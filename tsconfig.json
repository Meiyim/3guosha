{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "useDefineForClassFields": false
  },
  "include": ["server/**/*.ts", "bot/**/*.ts"],
  "exclude": ["tests/**/*.ts"]
}
